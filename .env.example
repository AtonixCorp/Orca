# ============================================================================
# File: .env.example
# Purpose:
#   Template for environment variables. Copy to `.env` and fill in real values.
#   Never commit a populated `.env` — it is gitignored for safety.
# ============================================================================

# ---- Core ----
APP_ENV=development                 # development | staging | production
APP_NAME=SmartCito
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# ---- Security ----
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=change-me-to-a-long-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRES_MINUTES=60
CORS_ALLOWED_ORIGINS=http://localhost:5173

# ---- Database (PostgreSQL) ----
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=smartcito
POSTGRES_USER=smartcito
POSTGRES_PASSWORD=change-me

# ---- Cache (Redis) ----
REDIS_URL=redis://redis:6379/0

# ---- Streaming (Kafka) ----
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_SENSOR_TOPIC=smartcito.sensors.raw
# Set to true to publish every ingested reading to Kafka on startup.
KAFKA_PUBLISHER_ENABLED=false

# ---- IoT ingestion (MQTT) ----
# Set MQTT_ENABLED=true to start the MQTT bridge in the API process.
MQTT_ENABLED=false
MQTT_HOST=mqtt
MQTT_PORT=1883
MQTT_TOPIC=smartcito/sensors/+
MQTT_CLIENT_ID=smartcito-api

# ---- Observability ----
AUDIT_LOG_ENABLED=true
OTEL_EXPORTER_OTLP_ENDPOINT=
